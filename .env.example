# LLM Configuration for the LLMJudge artifact
#
# Supported providers: anthropic, openai, gemini
#
# Configuration priority:
# 1. System environment variables
# 2. This .env file
# 3. Default values

# Provider: anthropic, openai, or gemini
LLM_PROVIDER=anthropic

# Model name (provider-specific)
# Anthropic: claude-sonnet-4-20250514, claude-opus-4-20250514, claude-haiku-3-5-20240307
# OpenAI: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# Gemini: gemini-1.5-pro, gemini-1.5-flash
LLM_MODEL=claude-sonnet-4-5-20250929

# API key - set one of these based on your provider
# LLM_API_KEY=your-api-key-here

# Or use provider-specific keys:
# ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key
# GOOGLE_API_KEY=your-google-key
