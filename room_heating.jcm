mas room_heating {

    agent heating_controller: heating_agent.asl {
        focus: living_room.asl_patcher
    }
    agent energy_evaluator: evaluator_agent.asl {
        focus: living_room.heater, living_room.llm_judge
    }

    workspace living_room {
        artifact heater: org.hyperagents.demo.Heater(15.0)
        artifact window: org.hyperagents.demo.Window("tilted")
        artifact llm_judge: org.hyperagents.demo.LLMJudge()
        artifact account_builder: org.hyperagents.demo.AccountBuilder()
        artifact asl_patcher: org.hyperagents.demo.ASLPatcher()

        agents: heating_controller, energy_evaluator
    }

    asl-path: "src/main/jason"
    java-path: "src/main/cartago"
}
